              <table className="w-full text-left">
                <thead className="border-b border-surface-border">
                  <tr>
                    <th className="px-0 py-3 text-[10px] font-semibold text-content-muted uppercase tracking-widest">Пользователь</th>
                    <th className="px-4 py-3 text-[10px] font-semibold text-content-muted uppercase tracking-widest">Роль</th>
                    <th className="px-4 py-3 text-[10px] font-semibold text-content-muted uppercase tracking-widest text-right">Статус</th>
                  </tr>
                </thead>
                <tbody>
                  <tr className="border-b border-surface-border/50">
                    <td className="px-0 py-4 flex items-center gap-3">
                      <div className="w-7 h-7 bg-surface flex items-center justify-center font-semibold text-xs text-content-primary">
                        {userEmail ? userEmail[0].toUpperCase() : 'U'}
