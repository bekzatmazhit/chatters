                </div>
              </div>

              <h3 className="text-[10px] font-semibold text-content-muted uppercase tracking-widest mb-3">Способ оплаты</h3>
              <div className="flex items-center justify-between max-w-sm pb-2 border-b border-surface-border">
                <div className="flex items-center gap-3">
                  <div className="w-10 h-6 bg-surface flex items-center justify-center text-content-primary font-semibold text-[9px] uppercase tracking-widest">VISA</div>
                  <div>
                    <p className="text-[12px] font-medium text-content-primary font-mono-tabular">**** **** **** 4242</p>
                    <p className="text-[10px] text-content-secondary font-mono-tabular uppercase tracking-wider">Exp 12/28</p>
                  </div>
                </div>
                <button className="text-[11px] font-medium text-indigo hover:text-indigo/80 uppercase tracking-widest transition-colors">Изменить</button>
