                </div>
                <div>
                  <label className="block text-[10px] font-semibold text-content-muted mb-1 uppercase tracking-widest">Имя</label>
                  <input type="text" placeholder="Введите ваше имя" className="w-full bg-transparent border-b border-surface-border py-2 text-[13px] text-content-primary focus:outline-none focus:border-indigo transition-colors" />
                </div>
                <button className="bg-indigo hover:bg-indigo/90 text-white px-4 py-2 text-[13px] font-medium transition-colors mt-2">Сохранить</button>
              </div>
            </div>
