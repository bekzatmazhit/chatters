                      <span className="font-medium text-content-primary text-[13px]">{userEmail}</span>
                    </td>
                    <td className="px-4 py-4 text-[13px] text-content-secondary">Admin</td>
                    <td className="px-4 py-4 text-right">
                      <span className="text-positive text-[10px] font-medium uppercase tracking-widest">Активен</span>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          )}

          {/* BILLING TAB */}
          {activeTab === 'billing' && (
            <div className="animate-in fade-in duration-200">
              <h2 className="text-[14px] font-medium text-content-primary mb-6 border-b border-surface-border pb-2">Управление подпиской</h2>

              <div className="border-b border-surface-border pb-6 mb-6 flex justify-between items-center">
                <div>
